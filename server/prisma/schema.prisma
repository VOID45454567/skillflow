generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  MODERATOR
  USER
}

enum VerificationStatus {
  UNVERIFIED // Не верифицирован
  PENDING // Ожидает проверки
  VERIFIED // Верифицирован
  REJECTED // Отклонен
}

enum OrganizationRole {
  OWNER // Владелец
  ADMIN // Администратор
  MEMBER // Участник
}

enum CourseStatus {
  DRAFT // Черновик
  PENDING // На модерации
  PUBLISHED // Опубликован
  REJECTED // Отклонен
  ARCHIVED // В архиве
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseType {
  FREE
  PAID
  ORGANIZATION
}

enum ItemType {
  MODULE
  LESSON
}

enum UserAction {
  BANNED
  VERIFIED // ← ИСПРАВЛЕНО
  COMPLETE_LESSON // ← ИСПРАВЛЕНО
  COMPLETE_MODULE
  COMPLETE_COURSE
}

enum TransactionType {
  DEPOSIT // Пополнение баланса
  COURSE_PURCHASE // Покупка курса
  ORGANIZATION_FEE // Плата за организацию
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== MAIN MODELS ====================

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  login     String  @unique
  password  String
  avatarUrl String?
  balance   Int     @default(0) // Виртуальная валюта (в копейках/центах)
  role      Role    @default(USER)

  twoFactorSecret  String? // Секрет для 2FA
  twoFactorEnabled Boolean @default(false)

  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedOrganizations   Organization[]        @relation("Owner")
  organizationMembers  Member[]
  createdCourses       Course[]              @relation("Author")
  transactions         Transaction[]
  payments             Payment[]
  banInfo              BanInfo?
  appeals              Appeal[]
  courseProgress       UserCourseProgress[]
  completedItems       CompletedItem[]
  twoFactorBackupCodes TwoFactorBackupCode[]
  heatmapDatas         HeatmapData[]
  userActions          UserActions[]
  courses              Course[]
  refreshTokens        RefreshToken?

  @@map("users")
}

model TwoFactorBackupCode {
  id        Int      @id @default(autoincrement())
  code      String
  isUsed    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())

  @@unique([userId, code])
  @@map("two_factor_backup_codes")
}

// ==================== БАНЫ ====================

model BanInfo {
  id             Int       @id @default(autoincrement())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int       @unique
  reason         String
  detailedReason String?
  bannedAt       DateTime  @default(now())
  bannedUntil    DateTime?
  bannedBy       Int // ID админа

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  appeals   Appeal[]

  @@map("ban_info")
}

model Appeal {
  id           Int          @id @default(autoincrement())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  banInfo      BanInfo      @relation(fields: [banInfoId], references: [id])
  banInfoId    Int
  reason       String // Причина апелляции
  status       AppealStatus @default(PENDING)
  resolution   String? // Решение/комментарий модератора
  consideredBy Int? // ID модератора
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appeals")
}

// ==================== ТРАНЗАКЦИИ И ПЛАТЕЖИ ====================

model Transaction {
  id           Int             @id @default(autoincrement())
  user         User            @relation(fields: [userId], references: [id])
  userId       Int
  type         TransactionType
  amount       Int // Положительное/отрицательное число
  balanceAfter Int // Баланс после транзакции
  description  String?

  // Комиссия
  fee        Int?   @default(0)
  feePercent Float?

  // Связи
  payment   Payment?
  paymentId Int?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@map("transactions")
}

model Payment {
  id     Int           @id @default(autoincrement())
  user   User          @relation(fields: [userId], references: [id])
  userId Int
  amount Int // Сумма платежа
  fee    Int?          @default(0) // Комиссия
  status PaymentStatus @default(PENDING)

  // Для покупки курсов
  course   Course? @relation(fields: [courseId], references: [id])
  courseId Int?

  // Для пополнения баланса
  paymentMethod String? // Способ пополнения (card, crypto, etc)
  externalId    String? // ID во внешней платежной системе

  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  transactionId Int?         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([courseId])
  @@map("payments")
}

// ==================== ОРГАНИЗАЦИИ ====================

model Organization {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  logo        String?

  // Владелец
  owner   User @relation("Owner", fields: [ownerId], references: [id])
  ownerId Int

  // Настройки
  inviteCode String @unique // Уникальный код для приглашений

  // Платные функции
  paidUntil     DateTime? // До когда оплачена организация
  pricePerMonth Int       @default(1000) // Цена в виртуальной валюте

  // Модерация
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  members Member[]
  courses Course[]

  @@map("organizations")
}

model Member {
  id             Int              @id @default(autoincrement())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId Int
  role           OrganizationRole @default(MEMBER)

  // Должность/роль в организации (не системная)
  position String?

  joinedAt DateTime @default(now())

  @@unique([userId, organizationId])
  @@map("members")
}

// ==================== КУРСЫ ====================

model Course {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  previewUrl  String?

  status CourseStatus @default(DRAFT)
  level  CourseLevel  @default(BEGINNER)
  type   CourseType   @default(FREE)
  price  Int?

  author   User @relation("Author", fields: [authorId], references: [id])
  authorId Int

  // Организация
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?

  // Модерация
  moderatedBy  Int?
  moderatedAt  DateTime?
  rejectReason String?

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules        Module[]
  purchases      Payment[]
  progress       UserCourseProgress[]
  completedItems CompletedItem[]
  user           User?                @relation(fields: [userId], references: [id])
  userId         Int?

  @@index([status])
  @@index([authorId]) // ← ДОБАВЛЕНО
  @@index([organizationId])
  @@map("courses")
}

model Module {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  order       Int     @default(0)

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId Int

  lessons Lesson[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  userCourseProgresses UserCourseProgress[]
  completedItems       CompletedItem[]

  @@unique([courseId, order])
  @@map("modules")
}

model Lesson {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  order       Int     @default(0)

  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId Int

  // Контент (хранится как JSON)
  content   Json // { type: "text", content: "...", resources: [...] }
  resources Json? // Массив URL ресурсов

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  userCourseProgresses UserCourseProgress[]
  completedItems       CompletedItem[]

  @@unique([moduleId, order])
  @@map("lessons")
}

// ==================== ПРОГРЕСС ОБУЧЕНИЯ ====================

model UserCourseProgress {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId Int

  currentModule   Module? @relation(fields: [currentModuleId], references: [id])
  currentModuleId Int?
  currentLesson   Lesson? @relation(fields: [currentLessonId], references: [id])
  currentLessonId Int?

  progressPercent Float     @default(0)
  startedAt       DateTime  @default(now())
  lastActivityAt  DateTime  @default(now())
  completedAt     DateTime?

  @@unique([userId, courseId])
  @@map("user_course_progress")
}

model CompletedItem {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId Int

  // Выполненный элемент (может быть модуль или урок)
  module   Module? @relation(fields: [moduleId], references: [id])
  moduleId Int?
  lesson   Lesson? @relation(fields: [lessonId], references: [id])
  lessonId Int?

  itemType    ItemType
  completedAt DateTime @default(now())

  // Убеждаемся, что заполнено хотя бы одно из moduleId/lessonId
  @@index([userId, courseId])
  @@map("completed_items")
}

// ==================== СТАТИСТИКА ====================

model Stats {
  id   Int      @id @default(autoincrement())
  date DateTime @unique

  newUsers   Int @default(0)
  totalUsers Int @default(0)

  // Финансы
  totalDeposits  Int @default(0) // Сумма пополнений
  totalFees      Int @default(0) // Сумма комиссий
  totalPurchases Int @default(0) // Количество покупок

  // Курсы
  publishedCourses Int @default(0)
  completedCourses Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("daily_stats")
}

// Индекс для производительности
model HeatmapData {
  id     Int      @id @default(autoincrement())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  date   DateTime @map("date")
  count  Int      @default(0) // Количество действий в день

  @@unique([userId, date])
  @@index([userId, date])
  @@map("heatmap_data")
}

model UserActions {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade) // ← ИСПРАВЛЕНО
  userId    Int
  date      DateTime   @default(now())
  type      UserAction
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, date])
  @@index([type])
  @@map("user_actions")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  tokenValue String
  user       User     @relation(fields: [userId], references: [id])
  userId     Int      @unique
  expiriesAt DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

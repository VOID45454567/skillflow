// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserVerificationStatuses {
  VERIFIED
  PENDING
  REJECTED
  UNVERIFIED
}

enum VisibilityTypes {
  ORGANIZATION
  PUBLISHED
  DRAFT
}

enum Roles {
  ADMIN
  USER
}

enum PaymentMethod {
  CARD
  SBP
}

enum TransactionType {
  PURCHASE
  REFUND
  GIFT
}

enum ActionsTypes {
  VERIFY
  BAN
  UNBAN
  DENY
}

enum CourseLevels {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
}

enum TermTypes {
  CATEGORY
  TAG
}

model User {
  id               Int     @id @default(autoincrement())
  login            String
  email            String  @unique
  password         String
  avatarUrl        String? @map("avatar_url")
  enabledTwoFactor Boolean @default(false)
  balance          Int     @default(0)
  role             Roles   @default(USER)

  verificationStatus UserVerificationStatuses @default(UNVERIFIED)

  courses Course[]

  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  blockInfos BlockInfo[]

  bannedUsers BlockInfo[] @relation("BannedByUser")

  // Кто заблокировал этого пользователя
  bannedByUsers        BlockInfo[]           @relation("BannedUser")
  twoVerificationCodes TwoVerificationCode[]
  refreshTokens        RefreshToken[]
  payments             Payment[]
  transactions         Transaction[]         @relation("UserTransactions")
  receivedGifts        Transaction[]         @relation("GiftTransactions")
  organizations        Organization[]
  organizationMembers  OrganizationMember[]
  heatmapDatas         HeatmapData[]
  appeals              Appeal[]
  adminActions         AdminActions[]
  userCourseProgresses UserCourseProgress[]
  reviews              Review[]
  purchasedCourses     PurchasedCourse[]

  @@map("users")
}

model Course {
  id          Int             @id @default(autoincrement())
  title       String
  description String
  user        User            @relation(fields: [userId], references: [id])
  userId      Int
  lessons     Lesson[]
  isFree      Boolean         @default(true)
  price       Int?
  visibility  VisibilityTypes
  level       CourseLevels

  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  transactions         Transaction[]
  courseTerms          CourseTerm[]
  userCourseProgresses UserCourseProgress[]
  reviews              Review[]
  organization         Organization?        @relation(fields: [organizationId], references: [id])
  organizationId       Int?
  purchasedCourse      PurchasedCourse[]

  @@map("courses")
}

model Lesson {
  id    Int    @id @default(autoincrement())
  title String

  course   Course? @relation(fields: [courseId], references: [id])
  courseId Int?

  requredTime Int?

  order Int @default(0)

  goals String[]

  content Json

  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  userCourseProgresses UserCourseProgress[]

  @@map("lessons")
}

model BlockInfo {
  id Int @id @default(autoincrement())

  blockReason String

  bannedId Int
  bannedBy Int

  bannedUser   User @relation("BannedUser", fields: [bannedId], references: [id])
  bannedByUser User @relation("BannedByUser", fields: [bannedBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?

  appeal   Appeal?
  appealId Int?

  @@map("block_info")
}

model TwoVerificationCode {
  id     Int     @id @default(autoincrement())
  user   User    @relation(fields: [userId], references: [id])
  userId Int
  code   String
  isUsed Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model RefreshToken {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id])
  userId Int

  tokenValue String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Payment {
  id     Int           @id @default(autoincrement())
  user   User?         @relation(fields: [userId], references: [id])
  userId Int?
  method PaymentMethod

  count Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Transaction {
  id     Int  @id @default(autoincrement())
  user   User @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  course   Course?         @relation(fields: [courseId], references: [id])
  type     TransactionType
  price    Int?
  courseId Int?

  giftTo   User? @relation("GiftTransactions", fields: [giftToId], references: [id], onDelete: SetNull)
  giftToId Int?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Organization {
  id   Int    @id @default(autoincrement())
  name String

  logo String? @default("")

  description String
  images      String[]

  owner      User?    @relation(fields: [userId], references: [id])
  courses    Course[]
  inviteCode String   @unique

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  userId              Int
  organizationMembers OrganizationMember[]
}

model OrganizationMember {
  id Int @id @default(autoincrement())

  organizationId Int
  userId         Int

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([organizationId, userId])
}

model HeatmapData {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime
  actionsCount Int      @default(0)

  @@unique([userId, date]) // Уникальная комбинация пользователь + дата
  @@index([userId, date]) // Индекс для быстрого поиска
}

model Term {
  id Int @id @default(autoincrement())

  type TermTypes
  name String    @unique

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  courseTerms CourseTerm[]
}

model CourseTerm {
  term   Term   @relation(fields: [termId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  termId    Int
  courseId  Int

  @@id([termId, courseId])
}

model Appeal {
  id Int @id @default(autoincrement())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  text String

  banInfo   BlockInfo? @relation(fields: [banInfoId], references: [id])
  banInfoId Int?       @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    Int?
}

model AdminActions {
  id           Int          @id @default(autoincrement())
  admin        User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId       Int
  targetUserId Int
  actionType   ActionsTypes
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("admin_actions")
}

model UserCourseProgress {
  id Int @id @default(autoincrement())

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Course @relation(fields: [courseId], references: [id])

  currentLesson Lesson @relation(fields: [currentLessonId], references: [id])

  completedLessons Json?
  progress         Float @default(0)

  totalLessons          Int @default(0)
  completedLessonsCount Int @default(0)

  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  completedAt    DateTime?

  userId          Int
  currentLessonId Int
  courseId        Int

  @@unique([userId, courseId])
  @@map("user_course_progress")
}

model Review {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    Int?
  courseId  Int?
}

model PurchasedCourse {
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId Int

  purchasedAt DateTime @default(now())

  @@id([userId, courseId])
}

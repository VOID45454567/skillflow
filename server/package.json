{
  "name": "skillflow-server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/main.ts --outdir dist --target node",
    "start": "bun run dist/main.js",
    "start:dev": "bun --watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "clean": "rm -rf dist node_modules prisma/generated"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nestjs-minio": "^2.6.3",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.0.0"
  }
}